<div>
    <div class="drop-zone" id="dropZone">
        <input type="file" name="media[]" id="fileInput"
            multiple accept="image/jpeg,image/png,image/webp,image/gif,video/mp4,video/quicktime" />
        <div class="drop-icon">↑</div>
        <div class="drop-label">Drop files here</div>
        <div class="drop-sub">or click to browse · JPG, PNG, WEBP, GIF, MP4, MOV</div>
    </div>

    <!-- File queue (populated by JS) -->
    <ul class="queue" id="fileQueue"></ul>

    <div class="tips">
        <div class="tips-title">File notes</div>
        <ul>
            <li>Images: JPG or PNG, minimum 1200px on longest side</li>
            <li>For paintings and drawings, photograph in natural light if possible</li>
            <li>Maximum file size: 20 MB per file</li>
            <li>Multiple files can be added in one upload</li>
            <li>Title and section are required before uploading</li>
        </ul>
    </div>
</div>