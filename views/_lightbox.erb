<div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <div class="lightbox-placeholder" id="lightboxImg">Image</div>
    <div class="lightbox-caption" id="lightboxCaption"></div>
</div>

<script>
    let openLightbox = (src, title) => {
        const lb = document.getElementById('lightbox')
        const img = lb.querySelector('img') || document.createElement('img')
        img.src = src
        img.alt = title
        document.getElementById('lightboxCaption').textContent = title
        if (!lb.querySelector('img')) {
            document.getElementById('lightboxImg').replaceWith(img)
            img.id = 'lightboxImg'
        }
        lb.classList.add('open')
    }

    let closeLightbox = () => {
        document.getElementById('lightbox').classList.remove('open')
    }

    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') closeLightbox()
    })
</script>