<div class="page" id="paintings">
    <div class="page-header">
        <h1>Paintings</h1>
        <span class="sub">Oil · Acrylic · Mixed media</span>
    </div>
    <div class="art-grid" id="paintingsGrid">
        <% paintings.each do |painting| %>
            <div class="art-item" onclick="openLightbox('<%= painting.uri %>', '<%= painting.title %>')">
                <img class="art-thumb" src="<%= painting.uri %>" alt="<%= painting.title %>">
                <div class="art-caption"><strong><%= painting.title %></strong><%= painting.medium %> · <%= painting.dimension %> · <%= painting.year %></div>
            </div>
        <% end %>
    </div>
</div>