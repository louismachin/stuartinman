<div class="page" id="drawings">
    <div class="page-header">
        <h1>Drawings</h1>
        <span class="sub">Pencil · Ink · Charcoal</span>
    </div>
    <div class="art-grid" id="drawingsGrid">
        <% drawings.each do |drawing| %>
            <div class="art-item" onclick="openLightbox('<%= drawing.uri %>', '<%= drawing.title %>')">
                <img class="art-thumb" src="<%= drawing.uri %>" alt="<%= drawing.title %>">
                <div class="art-caption"><strong><%= drawing.title %></strong><%= drawing.medium %> · <%= drawing.dimension %> · <%= drawing.year %></div>
            </div>
        <% end %>
    </div>
</div>