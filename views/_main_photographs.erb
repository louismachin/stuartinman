<div class="page" id="photographs">
    <div class="page-header">
        <h1>Photographs</h1>
        <span class="sub">Digital · Film</span>
    </div>

    <!-- Link to existing Flickr/Instagram while collection is being built -->
    <div class="ext-box">
        <p>My photography archive is currently on Flickr. New work is being added here over time.</p>
        <a class="ext-link" href="https://www.flickr.com/photos/stuartinman/" target="_blank" rel="noopener">View on Flickr ↗</a>
        <a class="ext-link" href="https://www.instagram.com/inman.stuart/" target="_blank" rel="noopener">Instagram ↗</a>
    </div>

    <div class="art-grid photo-grid" id="photographsGrid">
        <% photographs.each do |photograph| %>
            <div class="art-item" onclick="openLightbox('<%= photograph.uri %>', '<%= photograph.title %>')">
                <img class="art-thumb" src="<%= photograph.uri %>" alt="<%= photograph.title %>">
                <div class="art-caption"><strong><%= photograph.title %></strong><%= photograph.year %></div>
            </div>
        <% end %>
    </div>
</div>
